  CardOpeningsEvent      CardOpeningsEvent[]      @relation("EventOpening")
  WhatsAppRedirectsEvent WhatsAppRedirectsEvent[] @relation("Event")
  CountLikesEvent        CountLikesEvent[]        @relation("Event")

  @@map("elementmapevent")
