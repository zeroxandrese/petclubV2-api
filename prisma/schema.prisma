model News {
  uid           String   @id @default(auto()) @map("_id") @db.ObjectId
  title         String
  bigUrlshort   String
  smallUrlshort String?
  descripcion   String?
  status        Boolean  @default(true)
  charged       DateTime @default(now())
  actionPlan    String   @default("NEW")

  comments Comments[]

  @@map("news")
}

model BusinessProfile {
  uid    String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [uid])

  businessName String
  ruc          String?
  address      String?
  phone        String?
  verified     Boolean @default(false)

  created DateTime @default(now())

  @@unique([userId])
  @@map("businessprofiles")
}

model Product {
  uid     String @id @default(auto()) @map("_id") @db.ObjectId
  ownerId String @db.ObjectId
  owner   User   @relation(fields: [ownerId], references: [uid])

  name        String
  description String?
  price       Float
  stock       Int     @default(0)

  image  String?
  status Boolean @default(true)

  created DateTime @default(now())

  orders OrderItem[]

  @@index([ownerId])
  @@map("products")
}

model Order {
  uid     String @id @default(auto()) @map("_id") @db.ObjectId
  buyerId String @db.ObjectId
  buyer   User   @relation(fields: [buyerId], references: [uid])

  total  Float
  status String @default("PENDING")

  paymentId String?
  created   DateTime @default(now())

  items           OrderItem[]
  payments        Payment[]
  marketplaceFees MarketplaceFee[]

  @@index([buyerId])
  @@map("orders")
}

model OrderItem {
  uid     String @id @default(auto()) @map("_id") @db.ObjectId
  orderId String @db.ObjectId
  order   Order  @relation(fields: [orderId], references: [uid])

  productId String  @db.ObjectId
  product   Product @relation(fields: [productId], references: [uid])

  price    Float
  quantity Int

  @@map("orderitems")
}

model Payment {
  uid     String @id @default(auto()) @map("_id") @db.ObjectId
  orderId String @db.ObjectId
  order   Order  @relation(fields: [orderId], references: [uid])

  gateway    String // stripe | mercadopago | etc
  externalId String // id del pago externo
  amount     Float
  status     String

  created DateTime @default(now())

  @@index([orderId])
  @@map("payments")
}

model MarketplaceFee {
  uid String @id @default(auto()) @map("_id") @db.ObjectId

  orderId String @db.ObjectId
  order   Order  @relation(fields: [orderId], references: [uid])

  businessId String @db.ObjectId
  business   User   @relation(fields: [businessId], references: [uid])

  feeAmount Float
  percent   Float

  paid Boolean @default(false)

  created DateTime @default(now())

  @@map("marketplacefees")
}

model Subscription {
  uid    String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [uid])

  plan      String
  price     Float
  startDate DateTime
  endDate   DateTime

  active Boolean @default(true)

  @@map("subscriptions")
}
